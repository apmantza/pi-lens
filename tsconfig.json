{
	"extends": "./tsconfig.build.json",
	"compilerOptions": {
		// Allow lint config to build to be able to check isolatedDeclarations
		"noEmit": false,
		"allowImportingTsExtensions": true,
		"rewriteRelativeImportExtensions": true,
	},
	"include": ["*.ts", "**/*.ts"],
	"exclude": ["node_modules", "dist", "out", "cases"]
}
