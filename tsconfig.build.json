{
	"compilerOptions": {
		"rootDir": ".",
		"outDir": "./out",
		"target": "esnext",
		"module": "preserve",
		"moduleResolution": "bundler",
		"lib": ["ESNext"],
		"types": ["node"],
		"strict": true,
		"composite": true,
		"declaration": true,
		"declarationMap": true,
		// "erasableSyntaxOnly": true,
		"esModuleInterop": true,
		"isolatedDeclarations": true,
		"isolatedModules": true,
		"skipLibCheck": true,
		"noImplicitOverride": true,
		"noImplicitReturns": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
	},
	"include": ["*.ts", "**/*.ts"],
	"exclude": ["node_modules", "dist", "out", "cases", "tests", "scripts"]
}
